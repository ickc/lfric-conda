#!/bin/bash
# Launcher for the science-suite examples (drop-in for the MO meto rose-stem
# launch-exe; the suite's [command] runs "$LAUNCH_SCRIPT/launch-exe").
#
# The conda environment brings its OWN MPI (mpich from conda-forge), so the
# launcher is that MPI's `mpiexec` -- not `srun`. This is the visible difference
# from the Spack repo's launch-exe, which must use srun so that cray-mpich talks
# to Slingshot over the cxi provider. Everything else is identical, including the
# dedicated-XIOS-server layout.
#
# XIOS in server mode requires client and server to share ONE MPI_COMM_WORLD, so
# they are launched as a single MPMD job -- Hydra's colon syntax here, `srun
# --multi-prog` there.
#
# Honours the same environment the suite already sets:
#   BIN_DIR, EXEC_NAME, EXTRA_NAMELIST_FILES (default configuration.nml),
#   XIOS_SERVER_MODE (True/False), TOTAL_RANKS (model ranks), XIOS_SERVER_RANKS.
# Requires xios_server.exe on PATH in server mode (the environment provides it).
#
# MPIEXEC overrides the launcher (e.g. `srun` on a machine where the conda mpich
# is built against the site PMI, or `mpiexec --oversubscribe` on a small runner).
set -eu

EXEC="${BIN_DIR:?BIN_DIR unset}/${EXEC_NAME:?EXEC_NAME unset}"
NAMELIST="${EXTRA_NAMELIST_FILES:-configuration.nml}"
MPIEXEC="${MPIEXEC:-mpiexec}"

if [ "${XIOS_SERVER_MODE:-False}" = "True" ]; then
  M="${TOTAL_RANKS:?TOTAL_RANKS unset}"               # model (client) ranks
  S="${XIOS_SERVER_RANKS:?XIOS_SERVER_RANKS unset}"   # dedicated XIOS server ranks
  XIOS_EXEC="$(command -v xios_server.exe)" \
    || { echo "launch-exe: xios_server.exe not on PATH" >&2; exit 1; }
  echo "launch-exe: $MPIEXEC -n $M $EXEC $NAMELIST : -n $S $XIOS_EXEC"
  exec $MPIEXEC -n "$M" "$EXEC" "$NAMELIST" : -n "$S" "$XIOS_EXEC"
else
  N="${TOTAL_RANKS:?TOTAL_RANKS unset}"
  echo "launch-exe: $MPIEXEC -n $N $EXEC $NAMELIST  (XIOS attached, no dedicated server)"
  exec $MPIEXEC -n "$N" "$EXEC" "$NAMELIST"
fi
